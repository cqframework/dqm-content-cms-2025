  }, {
    "url": "http://hl7.org/fhir/StructureDefinition/cqf-definitionTerm",
    "extension": [ {
      "url": "term",
      "valueString": "Blood glucose"
    }, {
      "url": "definition",
      "valueMarkdown": "Blood-glucose data refers to data from random, periprandial, or fasting tests; from capillary, serum, plasma, interstitial fluid, or whole-blood sources; using central laboratory device (CLD) or point-of-care (POC) testing. Data from continuous glucose monitoring (CGM) systems can only be captured if they are integrated into the EHR and exposed in the corresponding FHIR resources. Post-glucose administration tests are excluded. Events are based on the day/time the laboratory test was collected (drawn). If day/time collected is not available, the day/time the lab was ordered is used.\n"
    } ]
  }, {
    "url": "http://hl7.org/fhir/StructureDefinition/cqf-definitionTerm",
    "extension": [ {
      "url": "term",
      "valueString": "Emergency department (ED)/Observation (Obs) encounter"
    }, {
      "url": "definition",
      "valueMarkdown": "Any patient visit to an ED or observation location. One (1) patient visit equals one (1) encounter. ED/Observation encounters are considered outpatient locations.\n"
    } ]
  }, {
    "url": "http://hl7.org/fhir/StructureDefinition/cqf-definitionTerm",
    "extension": [ {
      "url": "term",
      "valueString": "Hypoglycemic medication"
    }, {
      "url": "definition",
      "valueMarkdown": "All currently and previously commercially available oral or injectable hypoglycemic medications in the United States.\n"
    } ]
  }, {
    "url": "http://hl7.org/fhir/StructureDefinition/cqf-definitionTerm",
    "extension": [ {
      "url": "term",
      "valueString": "Inpatient encounter"
    }, {
      "url": "definition",
      "valueMarkdown": "Includes all encounters in inpatient locations.\n"
    } ]
  }, {
    "url": "http://hl7.org/fhir/StructureDefinition/cqf-definitionTerm",
    "extension": [ {
      "url": "term",
      "valueString": "Mild hypoglycemia event"
    }, {
      "url": "definition",
      "valueMarkdown": "Blood glucose 54.0 mg/dL to 69.9 mg/dL as identified on CLD or prescription POC device with no subsequent repeat test for blood glucose with a result \\> 80 mg/dL within 5 minutes of the start of the initial low blood glucose test.\n"
    } ]
  }, {
    "url": "http://hl7.org/fhir/StructureDefinition/cqf-definitionTerm",
    "extension": [ {
      "url": "term",
      "valueString": "Moderate hypoglycemia event"
    }, {
      "url": "definition",
      "valueMarkdown": "Blood glucose 40.0 mg/dL to 53.9 mg/dL as identified on CLD or prescription POC device with no subsequent repeat test for blood glucose with a result \\> 80 mg/dL within 5 minutes of the start of the initial low blood glucose test.\n"
    } ]
  }, {
    "url": "http://hl7.org/fhir/StructureDefinition/cqf-definitionTerm",
    "extension": [ {
      "url": "term",
      "valueString": "Severe hypoglycemia event"
    }, {
      "url": "definition",
      "valueMarkdown": "Blood glucose \\< 40.0 mg/dL as identified on CLD or prescription POC device with no subsequent repeat test for blood glucose with a result \\> 80 mg/dL within 5 minutes of the start of the initial low blood glucose test.\n"
    } ]
  } ],
